  <!-- Cookie consent banner (minimal, non-intrusive) -->
  <div id="cookieBanner" role="dialog" aria-label="Cookie consent" style="display:none;position:fixed;bottom:24px;left:50%;transform:translateX(-50%);z-index:300;background:var(--bg-card);border:1.5px solid var(--border);border-radius:var(--r);padding:16px 24px;align-items:center;gap:20px;box-shadow:var(--sh-xl);max-width:580px;width:calc(100% - 36px);">
    <p style="font-size:13.5px;color:var(--text-2);margin:0;flex:1;">We use cookies to improve your experience. <a href="/privacy" style="color:var(--orange);">Learn more</a></p>
    <button onclick="acceptCookies()" class="btn btn-primary" style="padding:10px 20px;font-size:13px;white-space:nowrap;">Accept</button>
    <button onclick="dismissCookies()" style="background:none;border:none;color:var(--text-3);cursor:pointer;font-size:22px;line-height:1;" aria-label="Dismiss cookie banner">&times;</button>
  </div>

  <script>
    // ---------- Sticky nav ----------
    var nav = document.getElementById('nav');
    function onScroll() { nav.classList.toggle('solid', window.scrollY > 40); }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // ---------- Mobile menu ----------
    var burger = document.getElementById('burger');
    var mm = document.getElementById('mobileMenu');
    var mClose = document.getElementById('mobileClose');
    if (burger && mm) {
      function openMenu() {
        mm.removeAttribute('hidden');
        mm.classList.add('open');
        burger.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
        mClose && mClose.focus();
      }
      function closeMenu() {
        mm.classList.remove('open');
        setTimeout(function () { mm.setAttribute('hidden', ''); }, 400);
        burger.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      }
      burger.addEventListener('click', openMenu);
      mClose && mClose.addEventListener('click', closeMenu);
      mm.querySelectorAll('a').forEach(function (a) { a.addEventListener('click', closeMenu); });
      document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && mm.classList.contains('open')) closeMenu(); });
    }

    // ---------- Scroll reveal ----------
    var io = new IntersectionObserver(function (es) {
      es.forEach(function (e) {
        if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -6% 0px' });
    document.querySelectorAll('.rv').forEach(function (el) { io.observe(el); });

    // ---------- Count-up animation ----------
    function fmtNum(n) { return n.toLocaleString('en-IN'); }
    function animateCount(el) {
      if (el.dataset.text) { el.textContent = el.dataset.text; return; }
      var target = +el.dataset.count;
      var pre = el.dataset.prefix || '';
      var suf = el.dataset.suffix || '';
      var dur = 1600, t0 = null;
      function step(ts) {
        if (!t0) t0 = ts;
        var p = Math.min((ts - t0) / dur, 1);
        var ease = 1 - Math.pow(1 - p, 3);
        el.textContent = pre + fmtNum(Math.floor(ease * target)) + suf;
        if (p < 1) requestAnimationFrame(step);
        else el.textContent = pre + fmtNum(target) + suf;
      }
      requestAnimationFrame(step);
    }
    var cio = new IntersectionObserver(function (es) {
      es.forEach(function (e) { if (e.isIntersecting) { animateCount(e.target); cio.unobserve(e.target); } });
    }, { threshold: 0.5 });
    document.querySelectorAll('[data-count]').forEach(function (el) { cio.observe(el); });

    // ---------- Auto-dismiss flash ----------
    setTimeout(function () {
      document.querySelectorAll('.flash').forEach(function (el) {
        el.style.transition = 'opacity 0.5s';
        el.style.opacity = '0';
        setTimeout(function () { el.remove(); }, 500);
      });
    }, 5000);

    // ---------- 3D tilt cards ----------
    (function () {
      if (window.matchMedia('(pointer: coarse)').matches) return;
      var tiltEls = document.querySelectorAll('.give-card, .gallery-item, .stat-card, .testimonial, .vol-role, .hero-img, .trust-card, .cert-card');
      tiltEls.forEach(function (el) {
        el.addEventListener('mousemove', function (e) {
          var r = el.getBoundingClientRect();
          var x = (e.clientX - r.left) / r.width - 0.5;
          var y = (e.clientY - r.top) / r.height - 0.5;
          el.style.transform = 'perspective(900px) rotateY(' + (x * 8) + 'deg) rotateX(' + (-y * 8) + 'deg) translateY(-6px)';
        });
        el.addEventListener('mouseleave', function () { el.style.transform = ''; });
      });
      // Magnetic buttons
      document.querySelectorAll('.btn-primary, .btn-teal, .btn-white').forEach(function (btn) {
        btn.addEventListener('mousemove', function (e) {
          var r = btn.getBoundingClientRect();
          var x = (e.clientX - r.left) / r.width - 0.5;
          var y = (e.clientY - r.top) / r.height - 0.5;
          btn.style.transform = 'translate(' + (x * 8) + 'px,' + (y * 8 - 3) + 'px)';
        });
        btn.addEventListener('mouseleave', function () { btn.style.transform = ''; });
      });
    })();

    // ---------- Active nav link ----------
    (function () {
      var path = window.location.pathname;
      document.querySelectorAll('.nav-links a, .footer-grid nav a').forEach(function (a) {
        if (a.getAttribute('href') === path) {
          a.setAttribute('aria-current', 'page');
          a.classList.add('active');
        }
      });
    })();

    // ---------- Cookie consent ----------
    (function () {
      try {
        if (!localStorage.getItem('cookieConsent')) {
          var b = document.getElementById('cookieBanner');
          if (b) { b.style.display = 'flex'; }
        }
      } catch(e) {
        // localStorage blocked (private mode etc) — just hide banner
      }
    })();
    function acceptCookies() {
      try { localStorage.setItem('cookieConsent', '1'); } catch(e) {}
      var b = document.getElementById('cookieBanner');
      if (b) { b.style.opacity = '0'; b.style.transition = 'opacity 0.4s'; setTimeout(function () { b.style.display = 'none'; }, 400); }
    }
    function dismissCookies() { acceptCookies(); }

    // ---------- Newsletter ----------
    function handleNewsletterSignup(e) {
      e.preventDefault();
      var input = document.getElementById('nl-email');
      var btn   = e.target.querySelector('button');
      var email = input ? input.value.trim() : '';
      if (!email) return;

      btn.textContent = 'Subscribing...';
      btn.disabled    = true;

      fetch('/api/newsletter', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ email: email, source: 'footer' }),
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.success) {
          btn.textContent  = '✓ Subscribed!';
          input.value      = '';
          btn.style.background = 'var(--teal)';
        } else {
          btn.textContent = 'Try again';
          btn.disabled    = false;
          alert(data.message || 'Could not subscribe.');
        }
      })
      .catch(function() {
        btn.textContent = 'Error — retry';
        btn.disabled    = false;
      });
    }
  </script>
