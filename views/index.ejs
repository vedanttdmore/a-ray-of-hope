    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
  </button>
</div>

<!-- ============ THE REALITY ============ -->

<section class="section section-warm" id="about">
  <div class="wrap">
    <div class="sec-head rv">
      <p class="eyebrow">The Reality</p>
      <h2>Behind every statistic is a child waiting for change.</h2>
      <p class="lead">We don't run on pity. We run on the simple belief that childhood is not negotiable — and that ordinary people, acting together, can make it real.</p>
    </div>
    <div class="stats-row" style="margin-top:48px;">
      <div class="stat-card rv">
        <div class="stat-icon orange">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <div class="stat-num" data-count="333" data-suffix="M">0</div>
        <div class="stat-label">Children live in extreme poverty</div>
      </div>
      <div class="stat-card rv" style="transition-delay:.08s">
        <div class="stat-icon teal">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div class="stat-num" data-count="160" data-suffix="M">0</div>
        <div class="stat-label">Children trapped in child labour</div>
      </div>
      <div class="stat-card rv" style="transition-delay:.16s">
        <div class="stat-icon purple">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>
        </div>
        <div class="stat-num" data-count="148" data-suffix="M">0</div>
        <div class="stat-label">Under-fives stunted by hunger</div>
      </div>
      <div class="stat-card rv" style="transition-delay:.24s">
        <div class="stat-icon gold">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        </div>
        <div class="stat-num" data-text="₹40">₹40</div>
        <div class="stat-label">Feeds one child for a full day</div>
      </div>
    </div>
  </div>
</section>

<!-- ============ WAYS TO GIVE (Preview) ============ -->
<section class="section" id="give">
  <div class="wrap">
    <div class="sec-head text-center rv" style="margin:0 auto;">
      <p class="eyebrow">Ways to Give</p>
      <h2>Three ways to put hope in a child's hands.</h2>
    </div>
    <div class="give-grid">
      <div class="give-card rv">
        <div class="card-icon">💰</div>
        <h3>Donate Money</h3>
        <p>Every rupee is converted into meals, school kits and medicine — tracked publicly so you see exactly where it lands.</p>
        <div class="card-footer">Most flexible &middot; Fully traceable</div>
      </div>
      <div class="give-card rv" style="transition-delay:.08s">
        <div class="card-icon">👕</div>
        <h3>Give Clothes</h3>
        <p>Warm, clean, wearable clothing for children and families. We sort, wash and distribute through local chapters.</p>
        <div class="card-footer">Drop-off & pickup in <%= stats.cities %> cities</div>
      </div>
      <div class="give-card rv" style="transition-delay:.16s">
        <div class="card-icon">🍚</div>
        <h3>Give Food & Grains</h3>
        <p>Rice, lentils, oil, and ready meals for kitchens and shelters. Non-perishable staples feed a family for weeks.</p>
        <div class="card-footer">Bulk & corporate donations welcome</div>
      </div>
    </div>
    <div class="text-center rv" style="margin-top:48px;">
      <a href="/donate" class="btn btn-primary btn-lg">Go to Donation Page <span class="arr">&rarr;</span></a>
    </div>
  </div>
</section>

<!-- ============ IMPACT / TRANSPARENCY ============ -->
<section class="section section-warm" id="impact">
  <div class="wrap">
    <div class="sec-head rv">
      <p class="eyebrow">Transparency</p>
      <h2>Where every rupee goes.</h2>
      <p class="lead">No black box. We publish our allocation because trust is earned, not assumed.</p>
    </div>
    <div class="impact-bar rv">
      <div class="impact-seg" style="flex:72;background:var(--orange);">72% Programs</div>
      <div class="impact-seg" style="flex:16;background:var(--gold);color:var(--text);">16% Logistics</div>
      <div class="impact-seg" style="flex:12;background:var(--teal);">12% Ops</div>
    </div>
    <div class="impact-key rv">
      <span><i style="background:var(--orange)"></i>Meals, education & medicine</span>
      <span><i style="background:var(--gold)"></i>Transport & distribution</span>
      <span><i style="background:var(--teal)"></i>Staff & admin</span>
    </div>
    <div class="stats-row" style="margin-top:56px;">
      <div class="stat-card rv">
        <div class="stat-num" data-count="2400000" data-suffix="+">0</div>
        <div class="stat-label">Meals Served</div>
      </div>
      <div class="stat-card rv"><div class="stat-num" data-count="38000" data-suffix="+">0</div><div class="stat-label">Children Supported</div></div>
      <div class="stat-card rv"><div class="stat-num" data-count="<%= stats.cities %>">0</div><div class="stat-label">City Chapters</div></div>
      <div class="stat-card rv"><div class="stat-num" data-count="14">0</div><div class="stat-label">Countries</div></div>
    </div>
  </div>
</section>

