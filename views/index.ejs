<%- include('partials/header') %>

<!-- ============ HERO ============ -->
<section class="hero" id="top">
  <div class="hero-bg">
    <img src="https://images.unsplash.com/photo-1488521787991-ed7bbaae773c?w=1920&q=80" alt="Children smiling" />
  </div>
  <div class="hero-orb o1"></div>
  <div class="hero-orb o2"></div>
  <div class="wrap">
    <div class="rv">
      <p class="eyebrow">A movement for every child's tomorrow</p>
      <h1 style="margin-top:18px;">Every child deserves a <span class="highlight">ray of hope.</span></h1>
      <p class="lead">Hunger, the streets, the brick kilns — these are not destiny. They are circumstances we can change, one child, one meal, one city at a time.</p>
      <div class="hero-cta">
        <a href="/donate" class="btn btn-primary btn-lg">Donate Now <span class="arr">&rarr;</span></a>
        <a href="/volunteer" class="btn btn-secondary btn-lg">Become a Volunteer</a>
      </div>
      <div class="hero-stats">
        <div class="hero-stat">
          <div class="num" data-count="2400000" data-suffix="+">0</div>
          <div class="label">Meals Served</div>
        </div>
        <div class="hero-stat">
          <div class="num" data-count="<%= stats.cities %>" data-suffix="">0</div>
          <div class="label">Cities Reached</div>
        </div>
        <div class="hero-stat">
          <div class="num" data-count="<%= stats.volunteers %>">0</div>
          <div class="label">Volunteers</div>
        </div>
      </div>
    </div>
    <div class="hero-images rv" style="transition-delay:.15s">
      <div class="hero-img">
        <img src="https://images.unsplash.com/photo-1542810634-71277d95dcbb?w=600&q=80" alt="Child with bright smile" />
      </div>
      <div class="hero-img">
        <img src="https://images.unsplash.com/photo-1509099836639-18ba1795216d?w=600&q=80" alt="Helping hands reaching out" />
      </div>
      <div class="hero-badge">
        <div class="badge-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
        </div>
        <div>
          <div class="badge-num" data-count="38000" data-suffix="+">0</div>
          <div class="badge-label">Children Supported</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============ PHOTO GALLERY ============ -->
