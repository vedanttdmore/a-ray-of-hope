        <div class="overlay"><span>Community support</span></div>
        <div class="zoom-hint"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg></div>
      </div>
      <div class="gallery-item rv" data-cat="education">
