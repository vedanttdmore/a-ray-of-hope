# ============================================
# A Ray of Hope — Environment Configuration
# ============================================
# Copy this file to .env and fill your values
# cp .env.example .env

# Server
PORT=3000
NODE_ENV=development
SESSION_SECRET=change-this-to-a-long-random-string-min-32-chars

# MongoDB (get free cluster at mongodb.com/atlas)
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGODB_URI=mongodb://localhost:27017/a-ray-of-hope

# Razorpay — Test keys from dashboard.razorpay.com (Settings > API Keys)
# Toggle to Test Mode first! Keys starting with rzp_test_ are safe.
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# UPI ID shown on the QR scan page
UPI_ID=arayofhope@upi

# Site URL (update when deploying)
SITE_URL=http://localhost:3000
